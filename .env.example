# ─── AWS Bedrock Configuration ───
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
BEDROCK_MODEL_ID=anthropic.claude-sonnet-4-5-20250929-v1:0

# ─── PostgreSQL Configuration ───
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/k8s_incidents

# ─── Kubernetes MCP Server ───
K8S_MCP_SERVER_COMMAND=kubectl-mcp-server
K8S_MCP_SERVER_ARGS=--transport stdio

# ─── Agent Configuration ───
POLLING_INTERVAL_SECONDS=60
AUTO_REMEDIATE=false
MONITOR_DURATION_MINUTES=5
TARGET_NAMESPACES=default

# ─── AlertManager / Grafana (EKS Monitoring Stack) ───
ALERTMANAGER_URL=http://alertmanager:9093
GRAFANA_URL=http://k8s-monitori-grafanaa-5e8579815c-745748481.ap-south-1.elb.amazonaws.com
GRAFANA_USERNAME=admin
GRAFANA_PASSWORD=

# ─── Email Alert Monitoring ───
EMAIL_IMAP_SERVER=imap.gmail.com
EMAIL_IMAP_PORT=993
EMAIL_ADDRESS=
EMAIL_PASSWORD=
ALERT_SENDER_EMAIL=
EMAIL_POLL_INTERVAL_SECONDS=30

# ─── Dashboard ───
DASHBOARD_HOST=0.0.0.0
DASHBOARD_PORT=8000
